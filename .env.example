# Copy this file to .env and adjust values for local development.
# docker-compose and the backend read these variables.

# ---- Deployment environment marker (used by /api/{environment}/v1) ----
APP_ENVIRONMENT=dev

# ---- PostgreSQL ----
POSTGRES_DB=docgen
POSTGRES_USER=docgen
POSTGRES_PASSWORD=docgen_local_pwd
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
IDEMPOTENCY_CACHE=redis

# ---- Kafka ----
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# in-process (default) or kafka
ASYNC_TRANSPORT=in-process

# ---- MinIO (object storage) ----
MINIO_ROOT_USER=docgen
MINIO_ROOT_PASSWORD=docgen_local_pwd
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=docgen-dev

# ---- Backend ----
BACKEND_PORT=8080
# Local-dev only secret; never reuse in real environments.
JWT_SECRET=local-dev-only-change-me-please-32bytes-min
# LibreOffice PDF conversion: cli (default) or docker-exec
LIBREOFFICE_COMMAND=soffice
LIBREOFFICE_CONVERSION_MODE=cli
LIBREOFFICE_DOCKER_CONTAINER=docgen-libreoffice

# ---- Frontend ----
FRONTEND_PORT=5173
